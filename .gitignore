extract_incident_details.py
fetch_all_detailed.py
fetch_all_incidents.py

# Incident data exports (sensitive company data)
*.csv
incident-sample.json
incidents-without-retro-commander-*.csv

# Screenshots (too large, not needed in git)
*.png

# Playwright automation artifacts
.playwright-mcp/

# Credentials (never commit these!)
.credentials/
**/jira-email.txt
**/jira-token.txt

